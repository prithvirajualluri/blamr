# Docker Compose environment — copy to .env in the repo root:
#   cp .env.docker.example .env

# Auth (change in production)
JWT_SECRET=dev-secret-change-in-production
BLAMR_INGEST_SECRET=dev-ingest-secret

# Workers — semantic drift + LLM blame reasons (local Ollama only)
BLAMR_SEMANTIC_DRIFT=true
BLAMR_ML_ENABLED=true
BLAMR_LLM_BLAME_REASON=true
BLAMR_LLM_BASE_URL=http://ollama:11434/v1
BLAMR_LLM_API_KEY=local
BLAMR_EMBEDDING_MODEL=nomic-embed-text
BLAMR_LLM_REASON_MODEL=llama3.2:3b

# LLM hop replay (API service) — uses real provider calls; falls back to Ollama when no cloud keys
BLAMR_REPLAY_MODEL=llama3.2:3b
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# Browser-facing URLs baked into the web image at build time.
VITE_API_BASE_URL=http://localhost:3000
VITE_INGEST_URL=http://localhost:3001
