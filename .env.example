# PostgreSQL
DATABASE_URL=postgresql://blamr:blamr_dev@localhost:5432/blamr

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=blamr
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Valkey / Redis
REDIS_URL=redis://localhost:6379

# Redpanda / Kafka
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=blamr

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
BLAMR_INGEST_SECRET=change-me-merkle-chain-signing-secret
WEBHOOK_SIGNING_SECRET=change-me-webhook-signing-secret

# Blame engine
BLAME_ENGINE_GRPC_URL=localhost:50051

# Frontend
VITE_API_BASE_URL=http://localhost:3000
VITE_INGEST_URL=http://localhost:3001
VITE_API_KEY=

# SDK (consumer-side)
BLAMR_API_KEY=bk_live_xxxxxxxxxxxxxxxx
BLAMR_ENDPOINT=http://localhost:3001/v1

# Local Ollama (workers — semantic drift + LLM blame reasons)
BLAMR_LLM_BASE_URL=http://localhost:11434/v1
BLAMR_LLM_API_KEY=local
BLAMR_SEMANTIC_DRIFT=true
BLAMR_EMBEDDING_MODEL=nomic-embed-text
BLAMR_SEMANTIC_SETTLE_MS=2000

# ML drift classification + root-cause ranker (workers)
BLAMR_ML_ENABLED=true
BLAMR_ML_FUSION_ALPHA=0.55
BLAMR_ML_MIN_DRIFT_CONF=0.42
# BLAMR_MUTATE_EDGES=0

BLAMR_LLM_BLAME_REASON=true
BLAMR_LLM_REASON_MODEL=llama3.2:3b

# Traefik / Gateway
TRAEFIK_API_HOST=api.localhost
TRAEFIK_INGEST_HOST=ingest.localhost
TRAEFIK_WEB_HOST=app.localhost
