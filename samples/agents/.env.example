# blamr ingest key (Settings → API & keys, scope: ingest:write)
BLAMR_API_KEY=
BLAMR_ENDPOINT=http://localhost:3001/v1

# Local Ollama (OpenAI-compatible API — same as platform workers)
BLAMR_LLM_BASE_URL=http://localhost:11434/v1
BLAMR_LLM_API_KEY=local
BLAMR_LLM_CHAT_MODEL=llama3.2:3b

# Optional — dev-only failure harness (required for npm run fail:*)
# BLAMR_FAILURE_TESTS=1
# BLAMR_FORCE_FAIL=1
# SUPPORT_QUERY=What is my remaining leave balance?
# RESEARCH_QUESTION=How does causal tracing work in multi-agent systems?
# INCIDENT_ALERT=CRITICAL: payment-api error rate 42%...

# Optional — per-workflow confidence pass threshold (0–1)
# BLAMR_CONFIDENCE_ACCEPT_LEVEL=0.75
# BLAMR_ACCEPT_INCIDENT_TRIAGE=0.80
