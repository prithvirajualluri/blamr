{
  "name": "@blamr/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "description": "blamr TypeScript SDK for multi-agent causal tracing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blamr-ai/blamr.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/blamr-ai/blamr/issues"
  },
  "homepage": "https://github.com/blamr-ai/blamr#readme",
